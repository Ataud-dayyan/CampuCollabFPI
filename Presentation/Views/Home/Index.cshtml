@using CampusCollabFPI.Data.Models
@using Microsoft.AspNetCore.Identity
@* @inject UserManager<ApplicationUser> UserManager *@
@model Presentation.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<link href="~/css/Dashboard.css" rel="stylesheet" />

<!-- Enhanced Hero Section -->
<div class="hero-section">
    <div class="hero-background">
        <div class="floating-shapes">
            <div class="shape shape-1"></div>
            <div class="shape shape-2"></div>
            <div class="shape shape-3"></div>
            <div class="shape shape-4"></div>
        </div>
    </div>
    <div class="hero-content">
        <div class="welcome-badge">
            @if (User.IsInRole("Student"))
            {
                <span class="badge-icon">🎓</span>
                <span>Student Portal</span>
            }
            else if (User.IsInRole("Lecturer"))
            {
                <span class="badge-icon">👨‍🏫</span>
                <span>Lecturer Dashboard</span>
            }
            else
            {
                <span class="badge-icon">⚡</span>
                <span>Admin Control</span>
            }
        </div>
        <h1 class="hero-title">Welcome back,</h1>
        <div class="info-value d-flex align-items-center">@Model.UserName</div>
        <p class="hero-subtitle">
            @if (User.IsInRole("Student"))
            {
                <span>Ready to collaborate and make an impact on campus? 🚀</span>
            }
            else
            {
                <span>Manage campus collaboration and oversee student activities 📊</span>
            }
        </p>
    </div>
</div>

<!-- Dashboard Content -->
<div class="dashboard-main">
    <div class="container">
        <!-- Enhanced Stats Cards -->
        <div class="stats-section">
            <h2 class="section-title">
                <span class="title-icon">📈</span>
                Quick Overview
            </h2>
            <div class="stats-grid">
                <a asp-controller="Group" asp-action="Index" class="stats-card groups-card">
                    <div class="card-glow"></div>
                    <div class="stats-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="stats-info">
                        <div class="stats-number">@Model.ActiveGroups</div>
                        <div class="stats-label">Active Groups</div>
                        <div class="stats-trend">↗️ Trending</div>
                    </div>
                    <div class="card-pattern"></div>
                </a>

                @if (User.IsInRole("Lecturer"))
                {
                    <a asp-controller="Group" asp-action="StudentList" class="stats-card students-card">
                        <div class="card-glow"></div>
                        <div class="stats-icon">
                            <i class="fas fa-graduation-cap"></i>
                        </div>
                        <div class="stats-info">
                            <div class="stats-number">@Model.TotalStudents</div>
                            <div class="stats-label">Total Students</div>
                            <div class="stats-trend">📚 Learning</div>
                        </div>
                        <div class="card-pattern"></div>
                    </a>
                }

                <div class="stats-card departments-card">
                    <div class="card-glow"></div>
                    <div class="stats-icon">
                        <i class="fas fa-building"></i>
                    </div>
                    <div class="card-pattern"></div>
                </div>
            </div>
        </div>

    </div>
</div>