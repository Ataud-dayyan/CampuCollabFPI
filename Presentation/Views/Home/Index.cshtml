@using CampusCollabFPI.Data.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@model Presentation.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<link href="~/css/Dashboard.css" rel="stylesheet" />

<!-- Enhanced Hero Section -->
<div class="hero-section">
    <div class="hero-background">
        <div class="floating-shapes">
            <div class="shape shape-1"></div>
            <div class="shape shape-2"></div>
            <div class="shape shape-3"></div>
            <div class="shape shape-4"></div>
        </div>
    </div>
    <div class="hero-content">
        <div class="welcome-badge">
            @if (User.IsInRole("Student"))
            {
                <span class="badge-icon">🎓</span>
                <span>Student Portal</span>
            }
            else if (User.IsInRole("Lecturer"))
            {
                <span class="badge-icon">👨‍🏫</span>
                <span>Lecturer Dashboard</span>
            }
            else
            {
                <span class="badge-icon">⚡</span>
                <span>Admin Control</span>
            }
        </div>
        <h1 class="hero-title">Welcome back, <span class="highlight">@UserManager.GetUserName(User)</span>!</h1>
        <p class="hero-subtitle">
            @if (User.IsInRole("Student"))
            {
                <span>Ready to collaborate and make an impact on campus? 🚀</span>
            }
            else
            {
                <span>Manage campus collaboration and oversee student activities 📊</span>
            }
        </p>
    </div>
</div>

<!-- Dashboard Content -->
<div class="dashboard-main">
    <div class="container">
        <!-- Enhanced Stats Cards -->
        <div class="stats-section">
            <h2 class="section-title">
                <span class="title-icon">📈</span>
                Quick Overview
            </h2>
            <div class="stats-grid">
                <a asp-controller="Group" asp-action="Index" class="stats-card groups-card">
                    <div class="card-glow"></div>
                    <div class="stats-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="stats-info">
                        <div class="stats-number">@Model.ActiveGroups</div>
                        <div class="stats-label">Active Groups</div>
                        <div class="stats-trend">↗️ Trending</div>
                    </div>
                    <div class="card-pattern"></div>
                </a>

                @if (User.IsInRole("Lecturer"))
                {
                    <a asp-controller="Group" asp-action="StudentList" class="stats-card students-card">
                        <div class="card-glow"></div>
                        <div class="stats-icon">
                            <i class="fas fa-graduation-cap"></i>
                        </div>
                        <div class="stats-info">
                            <div class="stats-number">@Model.TotalStudents</div>
                            <div class="stats-label">Total Students</div>
                            <div class="stats-trend">📚 Learning</div>
                        </div>
                        <div class="card-pattern"></div>
                    </a>
                }

                <div class="stats-card departments-card">
                    <div class="card-glow"></div>
                    <div class="stats-icon">
                        <i class="fas fa-building"></i>
                    </div>
                    <div class="stats-info">
                        <div class="stats-number">@Model.MyGroups</div>
                        <div class="stats-label">@(User.IsInRole("Student") ? "My Groups" : "Departments")</div>
                        <div class="stats-trend">✨ Active</div>
                    </div>
                    <div class="card-pattern"></div>
                </div>
            </div>
        </div>

        <!-- Enhanced Trending Groups -->
        <div class="section trending-section">
            <h2 class="section-title">
                <span class="title-icon">🔥</span>
                Trending Groups
                <span class="title-decoration"></span>
            </h2>
            <div class="groups-grid">
                @foreach (var group in Model.TrendingGroups)
                {
                    <div class="group-card">
                        <div class="group-card-glow"></div>
                        <div class="group-header">
                            <div class="group-icon">
                                <i class="fas fa-users"></i>
                                <div class="icon-pulse"></div>
                            </div>
                            <div class="group-info">
                                <h4>@group.Name</h4>
                                <div class="member-badge">
                                    <i class="fas fa-user-friends"></i>
                                    <span>@group.MemberCount members</span>
                                </div>
                            </div>
                            <div class="trending-indicator">
                                <span class="pulse-dot"></span>
                                Hot
                            </div>
                        </div>
                        <p class="group-description">@group.Description</p>
                        <div class="group-footer">
                            <a asp-controller="Group" asp-action="Details" asp-route-id="@group.Id" class="btn-primary">
                                <i class="fas fa-arrow-right"></i>
                                View Group
                            </a>
                            @if (!string.IsNullOrEmpty(group.LeaderName))
                            {
                                <div class="group-leader">
                                    <i class="fas fa-crown"></i>
                                    <span>@group.LeaderName</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>