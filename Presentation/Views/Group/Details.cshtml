@model Data.Model.GroupModel
@using CampusCollabFPI.Data.Models
@using Data.Model
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Group Details";
    var currentUserId = UserManager.GetUserId(User);
    var isOwner = Model.CreatedById == currentUserId;
    var isLecturer = User.IsInRole("Lecturer");
    var isMember = Model.Members.Any(m => m.UserId == currentUserId);
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
<link href="~/css/groupdetails.css" rel="stylesheet" />

<div class="details-container">

    <a asp-action="Index" class="back-link">
        <i class="fas fa-arrow-left"></i> Back to Groups
    </a>

    <div class="details-hero">
        <div class="details-hero-body">
            <h1 class="details-title">@Model.Name</h1>
            <div class="details-meta">
                <span class="meta-chip"><i class="fas fa-university"></i> @Model.Faculty</span>
                <span class="meta-chip"><i class="fas fa-building"></i> @Model.Department</span>
                <span class="meta-chip"><i class="fas fa-layer-group"></i> Level @Model.SchoolLevel</span>
                <span class="meta-chip"><i class="fas fa-crown"></i> @Model.CreatedByUser?.UserName</span>
            </div>
        </div>

        <div class="details-hero-actions">
            @if (isMember)
            {
                <form asp-action="Leave" method="post" style="display:inline;">
                    <input type="hidden" name="groupId" value="@Model.Id" />
                    <button type="submit" class="btn btn-outline-danger btn-sm"
                            onclick="return confirm('Are you sure you want to leave this group?')">
                        <i class="fas fa-sign-out-alt"></i> Leave Group
                    </button>
                </form>
            }
            @if (isLecturer && isOwner)
            {
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger btn-sm"
                   onclick="return confirm('Delete this group? This cannot be undone.')">
                    <i class="fas fa-trash-alt"></i> Delete Group
                </a>
            }
        </div>
    </div>

    @if(isLecturer && isOwner)
    {
        <div class="detail-card">
            <div class="detail-card-header">
                <span class="card-icon"><i class="fas fa-book-open"></i></span>
                <h2>Upload Course Material</h2>
            </div>
            <div class="detail-card-body">
                <form asp-action="UploadMaterial" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="groupId" value="@Model.Id" />
                    <div class="form-group">
                        <label>Select PDF or Material:</label>
                        <input type="file" name="postedFile" class="form-control" accept=".pdf,.doc,.docx" />
                    </div>
                    <button type="submit" class="btn btn-primary">Upload</button>
                </form>
            </div>
        </div>
    }
    <div class="detail-card">
        <div class="detail-card-header">
            <span class="card-icon"><i class="fas fa-book-open"></i></span>
            <h2>Course Materials</h2>
        </div>
        <div class="detail-card-body">
            <table class="table">
                <thead>
                    <tr>
                        <th>Material Name</th>
                        <th>Uploaded On</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.CourseMaterials)
                    {
                        <tr>
                            <td>@item.FileName</td>
                            <td>@item.UploadDate.ToShortDateString()</td>
                            <td>
                                <a href="@item.FilePath" download="@item.FileName" class="btn btn-success">
                                    Download
                                </a>
                                @if (isLecturer && isOwner)
                                {
                                    <form asp-action="DeleteMaterial" asp-route-id="@item.Id" method="post" style="display:inline;">
                                        <button type="submit" class="btn btn-danger btn-sm"
                                                onclick="return confirm('Delete this file?')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="detail-card">
        <div class="detail-card-header">
            <span class="card-icon"><i class="fas fa-users"></i></span>
            <h2>Members <span class="count-badge">@Model.Members.Count()</span></h2>
        </div>
        <div class="detail-card-body">
            <div class="members-grid">
                @foreach (var member in Model.Members)
                {
                    var avatar = (member.User as ApplicationUser)?.Avatar;
                    var memberId = member.UserId;

                    <div class="member-card">
                        <div class="member-avatar-wrap">
                            @if (!string.IsNullOrEmpty(avatar))
                            {
                                <img src="~/images/avatars/@avatar" alt="Avatar" class="member-avatar" />
                            }
                            else
                            {
                                <img src="~/images/avatars/default.png" alt="Avatar" class="member-avatar" />
                            }
                        </div>
                        <div class="member-details">
                            <span class="member-name">@member.User.UserName</span>
                            @if (isLecturer && isOwner)
                            {
                                <button type="button" class="btn btn-outline-danger btn-xs"
                                        onclick="toggleRemoveButton('@memberId')">
                                    <i class="fas fa-user-minus"></i> Remove
                                </button>
                                <form asp-action="RemoveStudent" method="post"
                                      id="removeForm-@memberId" class="remove-form" style="display:none;">
                                    <input type="hidden" name="groupId" value="@Model.Id" />
                                    <input type="hidden" name="userId" value="@memberId" />
                                    <span class="remove-confirm-label">Confirm remove?</span>
                                    <button type="submit" class="btn btn-danger btn-xs">
                                        <i class="fas fa-check"></i> Yes
                                    </button>
                                    <button type="button" class="btn btn-secondary btn-xs"
                                            onclick="cancelRemove('@memberId')">
                                        <i class="fas fa-times"></i> Cancel
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (isLecturer && isOwner)
    {
        var groupMemberIds = Model.Members.Select(m => m.UserId).ToList();
        var allStudents = ViewBag.AllStudents as List<ApplicationUser>;
        var availableStudents = allStudents?
        .Where(s => !groupMemberIds.Contains(s.Id))
        .ToList() ?? new List<ApplicationUser>();

        <div class="detail-card detail-card-accent">
            <div class="detail-card-header">
                <span class="card-icon card-icon-green"><i class="fas fa-user-plus"></i></span>
                <h2>Add Student</h2>
            </div>
            <div class="detail-card-body">
                <form asp-action="AddStudent" method="post" class="add-student-form">
                    <input type="hidden" name="groupId" value="@Model.Id" />
                    <div class="add-student-row">
                        <div class="add-student-select-wrap">
                            <label class="form-label" for="studentSelect">Select a student to add</label>
                            <select name="studentId" id="studentSelect" class="form-select" required>
                                <option value="">— Choose a student —</option>
                                @foreach (var student in availableStudents)
                                {
                                    <option value="@student.Id">@student.DisplayName (@student.Email)</option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-success add-btn">
                            <i class="fas fa-plus"></i> Add Student
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="detail-card">
        <div class="detail-card-header">
            <span class="card-icon"><i class="fas fa-comments"></i></span>
            <h2>Group Discussion</h2>
        </div>
        <div class="detail-card-body">

            @if (User.Identity.IsAuthenticated)
            {
                <div class="post-composer">
                    <form asp-controller="Group" asp-action="PostMessage" method="post">
                        <input type="hidden" name="groupId" value="@Model.Id" />
                        <textarea name="content" class="post-textarea"
                              placeholder="Share something with the group..." required></textarea>
                        <div class="composer-footer">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-paper-plane"></i> Post Message
                            </button>
                        </div>
                    </form>
                </div>

                @if (Model.Posts.Any())
                {
                    <div class="posts-list">
                        @foreach (var post in Model.Posts.OrderByDescending(p => p.PostedAt))
                        {
                            <div class="post-card">
                                <div class="post-header">
                                    <div class="post-avatar-initial">
                                        @post.User.UserName.Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <div class="post-author">@post.User.UserName</div>
                                        <div class="post-time">
                                            @post.PostedAt.ToString("MMM dd, yyyy 'at' h:mm tt")
                                        </div>
                                    </div>
                                </div>
                                <div class="post-content">@post.Content</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-discussion">
                        <i class="fas fa-comments"></i>
                        <p>No messages yet. Be the first to start a discussion!</p>
                    </div>
                }
            }
            else
            {
                <div class="empty-discussion">
                    <i class="fas fa-lock"></i>
                    <p>Please log in to view and participate in discussions.</p>
                </div>
            }
        </div>
    </div>

</div>

@if (TempData["PostNotification"] != null)
{
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1100;">
        <div class="toast align-items-center text-white bg-primary border-0 show" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">@Html.Raw(TempData["PostNotification"])</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>
    <script>
        setTimeout(() => {
            let toastEl = document.querySelector('.toast');
            if (toastEl) toastEl.remove();
        }, 3000);
    </script>
}

@section Scripts {
    <script src="~/js/groupdetails.js"></script>
    <script>
        function toggleRemoveButton(userId) {
            document.querySelectorAll('.remove-form').forEach(f => f.style.display = 'none');
            const form = document.getElementById('removeForm-' + userId);
            if (form) form.style.display = 'flex';
        }

        function cancelRemove(userId) {
            const form = document.getElementById('removeForm-' + userId);
            if (form) form.style.display = 'none';
        }
    </script>
}
