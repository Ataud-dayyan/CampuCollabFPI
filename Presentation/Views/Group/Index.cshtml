@model IEnumerable<Data.Model.GroupModel>
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@using CampusCollabFPI.Data.Models
@{
    ViewData["Title"] = "Groups";
    var currentUserId = UserManager.GetUserId(User);
    var isLecturer = User.IsInRole("Lecturer");
    var isStudent = User.IsInRole("Student");

    // Get ALL groups the student belongs to, not just the first one
    var studentGroups = isStudent
        ? Model.Where(g => g.Members.Any(m => m.UserId == currentUserId)).ToList()
        : new List<Data.Model.GroupModel>();    
    var isUserInAnyGroup = studentGroups.Any();
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
<link href="~/css/groupList.css" rel="stylesheet" />

<div class="groups-container">

    <div class="page-header">
        <div>
            <h1 class="page-title">Study Groups</h1>
            <p class="page-subtitle">
                @if (isLecturer)
                {
                    <span>Join groups to manage and collaborate with students</span>
                }
                else
                {
                    <span>@Model.Count() group@(Model.Count() == 1 ? "" : "s") available</span>
                }
            </p>
        </div>
        @if (isLecturer)
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus"></i>
                Create Group
            </a>
        }
    </div>

    @if (isStudent)
    {
        if (isUserInAnyGroup)
        {
            <div class="status-alert status-info">
                <div class="status-icon-wrap status-info">
                    <i class="fas fa-layer-group"></i>
                </div>
                <div class="status-content">
                    <h4>
                        You're in
                        <strong>@string.Join(", ", studentGroups.Select(g => g.Name))</strong>
                    </h4>
                    <p>You can browse all groups but only a group's lecturer can add you to others.</p>
                </div>
            </div>
        }
        else
        {
            <div class="status-alert status-warning">
                <div class="status-icon-wrap status-warning">
                    <i class="fas fa-exclamation"></i>
                </div>
                <div class="status-content">
                    <h4>You're not in a group yet</h4>
                    <p>Contact your lecturer to be added to a study group.</p>
                </div>
            </div>
        }
    }

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="fas fa-users"></i>
            </div>
            <h3>No groups yet</h3>
            <p>Create a group to get started.</p>
        </div>
    }

    @if (Model.Any())
    {
        <div class="groups-grid">
            @foreach (var group in Model)
            {
                // Per-card membership checks
                var isMember = group.Members.Select(m => m.UserId).Contains(currentUserId);
                var isGroupOwner = group.CreatedById == currentUserId;

                // For students: are they a member of THIS specific group?
                var isMyGroup = isStudent && isMember;
                // A student who is NOT a member of this card's group is locked out
                var isLocked = isStudent && !isMember;

                <div class="group-card @(isMyGroup ? "card-current" : "") @(isLocked ? "card-locked" : "")">

                    @if (isMyGroup)
                    {
                        <div class="card-badge badge-current">
                            <i class="fas fa-check-circle"></i> Your Group
                        </div>
                    }
                    else if (isLocked)
                    {
                        <div class="card-badge badge-locked">
                            <i class="fas fa-lock"></i> Locked
                        </div>
                    }
                    else if (isLecturer && isGroupOwner)
                    {
                        <div class="card-badge badge-owner">
                            <i class="fas fa-crown"></i> Owner
                        </div>
                    }

                    <div class="group-header">
                        <div class="group-icon @(isMyGroup ? "icon-current" : "") @(isLocked ? "icon-locked" : "")">
                            <i class="fas fa-users"></i>
                        </div>
                        <div class="group-info">
                            <h3>@group.Name</h3>
                            <p><i class="fas fa-book-open"></i> @group.CourseName</p>
                        </div>
                    </div>

                    <div class="group-meta">
                        <span class="meta-pill">
                            <i class="fas fa-user-friends"></i>
                            @group.Members.Count() member@(group.Members.Count() == 1 ? "" : "s")
                        </span>
                    </div>

                    <div class="group-actions">

                        @if (isLecturer)
                        {
                            if (!isMember)
                            {
                                <form asp-action="Join" method="post" style="display:inline;">
                                    <input type="hidden" name="groupId" value="@group.Id" />
                                    <button type="submit" class="btn btn-success">
                                        <i class="fas fa-user-plus"></i> Join Group
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a asp-action="Details" asp-route-id="@group.Id" class="btn btn-primary">
                                    <i class="fas fa-eye"></i> View Details
                                </a>

                                if (isGroupOwner)
                                {
                                    var groupMemberIds = group.Members.Select(m => m.UserId).ToList();
                                    var allStudents = ViewBag.AllStudents as List<ApplicationUser>;
                                    var availableStudents = allStudents?
                                    .Where(s => !groupMemberIds.Contains(s.Id))
                                    .ToList() ?? new List<ApplicationUser>();

                                    <form asp-action="AddStudent" method="post" class="add-student-form">
                                        <input type="hidden" name="groupId" value="@group.Id" />
                                        <select name="studentId" class="form-select" required>
                                            <option value="">— Add student —</option>
                                            @foreach (var student in availableStudents)
                                            {
                                                <option value="@student.Id">@student.DisplayName (@student.Email)</option>
                                            }
                                        </select>
                                        <button type="submit" class="btn btn-success">
                                            <i class="fas fa-user-plus"></i> Add
                                        </button>
                                    </form>
                                }
                            }
                        }

                        @if (isStudent)
                        {
                            if (isMyGroup)
                            {
                                <a asp-action="Details" asp-route-id="@group.Id" class="btn btn-primary">
                                    <i class="fas fa-eye"></i> View Details
                                </a>
                            }
                            else
                            {
                                <span class="action-hint">
                                    <i class="fas fa-lock"></i>
                                    Only a group lecturer can add you here
                                </span>
                            }
                        }

                    </div>
                </div>
            }
        </div>
    }

</div>
